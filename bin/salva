#!/usr/bin/env python3
"""Wrapper eseguibile: lancia salva senza installarlo.

Aggiunge la radice del progetto al path e chiama la CLI.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from salva.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
